<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="fapesnap"
        Arguments=""
        InstallLocation="C:\Program Files\Fapesnap\Fapesnap">
    </Installer>
    <PackageInformation
        PackageName="Fapesnap"
        PackageDisplayName="Fapesnap"
        PublisherName="CN=Fapesnap"
        PublisherDisplayName="Fapesnap"
        Version="2.2.3.0"
        PackageDescription="Nudes downloader">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="github.com/nakrovati/fapesnap"
                Description="Nudes downloader"
                DisplayName="Fapesnap"
                ExecutableName="fapesnap"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Fapesnap</DisplayName>
            <PublisherDisplayName>Fapesnap</PublisherDisplayName>
            <Description>Nudes downloader</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="fapesnap.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
